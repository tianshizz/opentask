# Database
DATABASE_URL=postgresql://opentask:opentask_dev_password@localhost:5432/opentask

# Redis
REDIS_URL=redis://localhost:6379

# Object Storage (MinIO/S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_password
MINIO_BUCKET_NAME=opentask-artifacts
MINIO_USE_SSL=false

# API
API_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY_SECRET=your-api-key-secret-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3001

# Channels - Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Channels - Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Channels - Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Agent Defaults
DEFAULT_AGENT_TIMEOUT_MS=300000
MAX_ATTEMPTS_PER_TICKET=10
